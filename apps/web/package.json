{
  "name": "@visitflorence/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:seed": "dotenv -e .env.local -- tsx lib/db/seed.ts",
    "db:fix-contacts": "dotenv -e .env.local -- tsx lib/db/fix-sister-contacts.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/analytics": "^1.4.1",
    "@vercel/speed-insights": "^1.2.0",
    "@visitflorence/shared": "*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.3",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "geist": "^1.3.1",
    "lucide-react": "^0.469.0",
    "next": "^16.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.29.1",
    "@tailwindcss/postcss": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
